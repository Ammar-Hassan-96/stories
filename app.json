{
  "expo": {
   "name": "عالم القصص",
    "slug": "stories",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#130C2C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.storiesworld.arabic",
      "userInterfaceStyle": "automatic"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#130C2C"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.storiesworld.arabic"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "supportsRTL": true,
      "eas": {
        "projectId": "b04232ac-23e7-4ba1-872d-1dfa3eaa0055"
      }
    },
    "plugins": [
      "expo-font"
    ]
  }
}
